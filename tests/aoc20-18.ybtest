====[ source code ]====
import aoc
import text

fun ~reduce_impl[T](init: T, cont: (T) -> ~T): T = {
  case
  | next: if cont?(init)
    return: reduce_impl(next, cont)
  | let return = init
  \
}

fun ~reduce[T](init: ~T, cont: (T) -> ~T): T = {
  start: if init
  return: reduce_impl(start, cont)
}

fun ~atom: int = {
  case
  | return: if text.num
  | if /\(/, return: expect expr, expect /\)/
  \
}

fun ~expr_cont(lhs: int): int = {
  case
  | if / \+ /, rhs: expect atom
    let return = lhs + rhs
  | if / \* /, rhs: expect atom
    let return = lhs * rhs
  \
}

fun ~expr: int = expect reduce(atom, expr_cont)

export
fun ~test = aoc.summap({
  return: if expr, if text.newline
})

====[ text 1 ]====
1 + 2 * 3 + 4 * 5 + 6
