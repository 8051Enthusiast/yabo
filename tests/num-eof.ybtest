====[ source code ]=====
import text

def ~constsize_num = {
  return: expect /[0-9]{4}/ |> text.num
  expect /, /
}

export
def ~test = {
  len: if text.num, if /\n/
  nums: [len]constsize_num
}

====[ text 1 ]====
4
0001, 0002, 0005, 1000,
#
====[ output 1 ]====
{
  "len": 4,
  "nums": [1, 2, 5, 1000]
}

====[ text 2 ]====
3
0001, 0002, 0005, 1000,
#
====[ output 2 ]====
{
  "len": 3,
  "nums": [1, 2, 5]
}
