====[ source code ]====
fun ~u8ptr[T](t: ~T) = {
  addr: if u8 is 0x01..0xff
  let return = t if at addr
}

export
def ~test = {
  case
  | if u8 is 0
  | next: if u8ptr(test)
  \
  val: u8
}

====[ binary 1 ]====
02 00 04 01 06 02 01 03

