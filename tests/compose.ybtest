====[ source code ]====
import text
def ~skip(skipper: ~[u8]) = {
    if skipper, return: if /.*/
}

def ~skip_4 = if skip(/..../)

def ~after_hello = if skip(/.*?hello/)

def ~skip_non_num = if skip(/[^0-9]*/)

export def ~test = if skip_4
                |> after_hello
                |> skip_non_num
                |> text.num

====[ text 1 ]====
hello agent 123 and hello agent 008!

====[ output 1 ]====
8

====[ text 2 ]====
####hello agent 123 and hello agent 008!

====[ output 2 ]====
123
