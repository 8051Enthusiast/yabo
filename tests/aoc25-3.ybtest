import text
import parse
import aoc

fun ~joltage_digit(n: int, clearance: int) = {
  d: if text.digit(10) is !eof
  case
  | if when?(d > n) then parse.lookahead([clearance] is !eof)
    case
    | return: if joltage_digit(d, clearance)
    | let return = d
    \
  | return: if joltage_digit(n, clearance)
  \
}

fun ~joltage(size: int, acc: int) = {
  case
  | let return = size if 0 then acc
  | d: expect joltage_digit(-1, size - 1)
    return: joltage(size - 1, 10 * acc + d)
  \
}

export
fun ~test = aoc.summap(text.line |> joltage(2, 0))

